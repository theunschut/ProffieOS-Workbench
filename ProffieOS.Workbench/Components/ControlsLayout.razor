@inject SaberStateService State
@inject ISnackbar Snackbar
@implements IDisposable

<div class="cmd-grid">
    <ControlButton Label="on"       Icon="@Icons.Material.Filled.PowerSettingsNew" Active="State.IsOn"  OnClick="TurnOn" />
    <ControlButton Label="off"      Icon="@Icons.Material.Filled.PowerOff"         Active="!State.IsOn" OnClick="TurnOff" />
    <ControlButton Label="clash"    Icon="@Icons.Material.Filled.Bolt"             OnClick='() => Cmd("clash")' />
    <ControlButton Label="blast"    Icon="@Icons.Material.Filled.FlashOn"          OnClick='() => Cmd("blast")' />
    <ControlButton Label="force"    Icon="@Icons.Material.Filled.AutoAwesome"      OnClick='() => Cmd("force")' />
    <ControlButton Label="lockup"   Icon="@Icons.Material.Filled.Lock"             OnClick='() => Cmd("lockup")' />
    <ControlButton Label="drag"     Icon="@Icons.Material.Filled.DragIndicator"    OnClick='() => Cmd("drag")' />
    <ControlButton Label="melt"     Icon="@Icons.Material.Filled.Whatshot"         OnClick='() => Cmd("melt")' />
    <ControlButton Label="stab"     Icon="@Icons.Material.Filled.NorthEast"        OnClick='() => Cmd("stab")' />
    <ControlButton Label="lightning" Icon="@Icons.Material.Filled.ElectricBolt"   OnClick='() => Cmd("lblock")' />
    <ControlButton Label="stop track" Icon="@Icons.Material.Filled.StopCircle"    OnClick="StopTrack" />
</div>
