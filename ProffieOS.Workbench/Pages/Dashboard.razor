@page "/dashboard"
@inject SaberConnectionService Connection
@inject SaberStateService State
@inject SaberCommandService Commands
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>ProffieOS Workbench</PageTitle>

@if (Connection.State == ConnectionState.Disconnected)
{
    <div class="hs-screen">
        <div class="hs-brand">
            <span class="starjedi-title hs-title">disconnected</span>
        </div>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="saber-btn"
                   OnClick="@(() => Nav.NavigateTo(""))">
            reconnect
        </MudButton>
    </div>
    return;
}

@if (Connection.State == ConnectionState.Reconnecting)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="reconnecting-banner">
        Reconnecting... please wait
    </MudAlert>
}

<div class="wb-shell">

    <!-- ── Header ──────────────────────────────────────────── -->
    <header class="wb-header">
        <span class="starjedi-title wb-title">Proffieos Workbench</span>
        <div class="wb-header-spacer"></div>
        <div class="wb-vol">
            <MudIcon Icon="@Icons.Material.Filled.VolumeUp"
                     Size="Size.Small"
                     Style="color:rgba(176,216,248,0.45); flex-shrink:0;" />
            <MudSlider T="int" Value="State.Volume" ValueChanged="OnVolumeChanged"
                       Min="0" Max="2000" Class="wb-vol-slider" />
            <span class="wb-vol-val">@State.Volume</span>
        </div>
        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Class="wb-battery"
                 Icon="@Icons.Material.Filled.BatteryChargingFull">
            @State.BatteryVoltage V
        </MudChip>
        @if (State.HasEditMode)
        {
            <MudTooltip Text="Edit Presets" Placement="Placement.Bottom" Delay="500">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Class="wb-icon-btn"
                               OnClick="@(() => Nav.NavigateTo("edit"))" />
            </MudTooltip>
        }
        @if (State.HasSettings)
        {
            <MudTooltip Text="Settings" Placement="Placement.Bottom" Delay="500">
                <MudIconButton Icon="@Icons.Material.Filled.Settings"
                               Class="wb-icon-btn"
                               OnClick="@(() => Nav.NavigateTo("settings"))" />
            </MudTooltip>
        }
    </header>

    <!-- ── Body: 3 columns ─────────────────────────────────── -->
    <div class="wb-body">

        <!-- Left: combat controls -->
        <aside class="wb-left">
            <div class="wb-pane-hdr">
                <span class="starjedi-title wb-pane-label">combat</span>
            </div>
            <ControlsLayout />
        </aside>

        <!-- Center: targeting reticle + active preset -->
        <main class="wb-center">
            <div class="reticle">
                <div class="arc-outer"></div>
                <div class="arc-inner"></div>
                <span class="r-mark r-n"></span>
                <span class="r-mark r-e"></span>
                <span class="r-mark r-s"></span>
                <span class="r-mark r-w"></span>
                <div class="reticle-core">
                    @if (State.Presets.Count > 0
                         && State.CurrentPresetIndex >= 0
                         && State.CurrentPresetIndex < State.Presets.Count)
                    {
                        <span class="r-sub">active preset</span>
                        <span class="starjedi-title r-title">
                            @State.Presets[State.CurrentPresetIndex].Name.Replace("\\n", " ")
                        </span>
                    }
                    else
                    {
                        <span class="r-sub">loading</span>
                    }
                </div>
            </div>
        </main>

        <!-- Right: track list -->
        <aside class="wb-right">
            <TracksPanel />
        </aside>

    </div>

    <!-- ── Footer: presets bar ─────────────────────────────── -->
    <PresetsBar />

</div>
