@page "/"
@inject SaberConnectionService Connection
@inject SaberStateService State
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>ProffieOS Workbench</PageTitle>

<div class="connect-page">
    <div class="connect-logo">
        <span class="starjedi-title">Proffieos<br />Workbench</span>
    </div>

    @if (!Connection.BluetoothAvailable && !Connection.UsbAvailable)
    {
        <MudAlert Severity="Severity.Error" Class="mt-4" Style="max-width:400px;">
            This browser supports neither Web Bluetooth nor WebUSB.
            Use a Chromium-based browser (Chrome, Edge).
        </MudAlert>
    }

    <div class="connect-buttons">
        @if (Connection.UsbAvailable)
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Large"
                       Class="saber-btn connect-btn"
                       Disabled="_busy"
                       OnClick="ConnectUsbAsync">
                @if (_busy && _connectingVia == "usb")
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                usb
            </MudButton>
        }

        @if (Connection.BluetoothAvailable)
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Large"
                       Class="saber-btn connect-btn"
                       Disabled="_busy"
                       OnClick="TogglePasswordField">
                ble
            </MudButton>
        }
    </div>

    <KnownDevicesPanel Disabled="_busy" OnConnect="ConnectKnownAsync" />

    @if (_showPassword)
    {
        <div class="password-area">
            <MudTextField @bind-Value="_password"
                          Label="Password (optional)"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="password-field"
                          OnKeyDown="OnPasswordKeyDown" />
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Class="saber-btn"
                       Disabled="_busy"
                       OnClick="ConnectBleAsync">
                @if (_busy && _connectingVia == "ble")
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                connect
            </MudButton>
        </div>
    }
</div>
