@page "/"
@inject SaberConnectionService Connection
@inject SaberStateService State
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>ProffieOS Workbench</PageTitle>

<div class="hs-screen">

    <div class="hs-brand">
        <span class="starjedi-title hs-title">Proffieos<br />Workbench</span>
        <span class="hs-tagline">saber control interface</span>
    </div>

    @if (!Connection.BluetoothAvailable && !Connection.UsbAvailable)
    {
        <MudAlert Severity="Severity.Error" Style="max-width:460px;">
            This browser supports neither Web Bluetooth nor WebUSB.
            Use a Chromium-based browser (Chrome, Edge).
        </MudAlert>
    }

    <div class="hs-divider">select protocol</div>

    <div class="hs-tiles">
        @if (Connection.UsbAvailable)
        {
            <div class="hs-tile @(_busy ? "hs-tile-busy" : "")" @onclick="ConnectUsbAsync">
                @if (_busy && _connectingVia == "usb")
                {
                    <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Usb" Class="hs-tile-icon" />
                }
                <span class="starjedi-title hs-tile-name">usb</span>
                <span class="hs-tile-desc">wired connection</span>
            </div>
        }

        @if (Connection.BluetoothAvailable)
        {
            <div class="hs-tile @(_busy ? "hs-tile-busy" : "")" @onclick="TogglePasswordField">
                @if (_busy && _connectingVia == "ble")
                {
                    <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Bluetooth" Class="hs-tile-icon" />
                }
                <span class="starjedi-title hs-tile-name">ble</span>
                <span class="hs-tile-desc">wireless connection</span>
            </div>
        }
    </div>

    @if (_showPassword)
    {
        <div class="hs-password">
            <MudTextField @bind-Value="_password"
                          Label="Password (optional)"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="hs-pw-field"
                          OnKeyDown="OnPasswordKeyDown" />
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Class="saber-btn"
                       Disabled="_busy"
                       OnClick="ConnectBleAsync">
                @if (_busy && _connectingVia == "ble")
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                connect
            </MudButton>
        </div>
    }

    <div class="hs-divider">previously paired</div>
    <KnownDevicesPanel Disabled="_busy" OnConnect="ConnectKnownAsync" />

</div>
