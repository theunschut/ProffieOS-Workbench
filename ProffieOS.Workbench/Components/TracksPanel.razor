@inject SaberStateService State
@inject ISnackbar Snackbar
@implements IDisposable

<div class="panel work-panel">
    <div class="panel-topline">
        <span class="panel-dot"></span>
        <span class="panel-topline-text">tracks</span>
    </div>
    <div class="panel-scroll">
        @if (!State.TrackList.Any())
        {
            <MudText Typo="Typo.caption" Class="empty-state-note">
                waiting for track list...
            </MudText>
        }
        else
        {
            <MudList T="string" Dense="true" Class="track-list">
                @foreach (var track in State.TrackList)
                {
                    if (track.Length <= 4) continue;
                    var t = track;
                    var parts = t.Split('/');
                    var title = parts[^1].Split('.')[0].ToLowerInvariant();
                    var isPlaying = t == State.CurrentTrack;

                    <MudListItem T="string"
                                 Class="@($"track-list-item{(isPlaying ? " active-track" : "")}")"
                                 OnClick="@(async _ => await PlayTrack(t))">
                        <div class="track-row">
                            <MudIcon Icon="@(isPlaying ? Icons.Material.Filled.PlayArrow : Icons.Material.Filled.MusicNote)"
                                     Size="Size.Small"
                                     Class="@(isPlaying ? "track-icon playing" : "track-icon")" />
                            <span class="starjedi-title track-name @(isPlaying ? "is-playing" : "")">
                                @title
                            </span>
                        </div>
                    </MudListItem>
                }
            </MudList>
        }
    </div>
</div>
