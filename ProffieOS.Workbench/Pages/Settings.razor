@page "/settings"
@inject SaberConnectionService Connection
@inject SaberStateService State
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>ProffieOS Workbench – Settings</PageTitle>

@if (Connection.State == ConnectionState.Disconnected)
{
    <div class="connect-page">
        <div class="connect-logo">
            <span class="starjedi-title">disconnected</span>
        </div>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="saber-btn"
                   OnClick="@(() => Nav.NavigateTo(""))">
            reconnect
        </MudButton>
    </div>
    return;
}

<div class="app-header">
    <MudTooltip Text="Back to dashboard" Placement="Placement.Bottom" Delay="400">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       Class="mode-btn"
                       OnClick="@(() => Nav.NavigateTo("dashboard"))" />
    </MudTooltip>
    <span class="starjedi-title app-title">settings</span>
    <div class="header-spacer"></div>
</div>

<div class="dashboard-panels">
    @if (_isLoading)
    {
        <div class="panel settings-panel">
            <div class="pa-4">
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            </div>
        </div>
    }
    else
    {
        <SettingsPanel />
    }
</div>
