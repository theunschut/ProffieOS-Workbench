@page "/edit"
@inject SaberConnectionService Connection
@inject SaberStateService State
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>ProffieOS Workbench – Edit</PageTitle>

@if (Connection.State == ConnectionState.Disconnected)
{
    <div class="hs-screen">
        <div class="hs-brand">
            <span class="starjedi-title hs-title">disconnected</span>
        </div>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="saber-btn"
                   OnClick="@(() => Nav.NavigateTo(""))">
            reconnect
        </MudButton>
    </div>
    return;
}

<header class="wb-header">
    <MudTooltip Text="Back to dashboard" Placement="Placement.Bottom" Delay="400">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       Class="wb-icon-btn"
                       OnClick="@(() => Nav.NavigateTo("dashboard"))" />
    </MudTooltip>
    <span class="starjedi-title wb-title">edit preset</span>
    <div class="wb-header-spacer"></div>
</header>

<div class="dashboard-panels edit-layout">
    <PresetsPanel Mode="@("Edit")" />
    <EditPanel />
</div>
