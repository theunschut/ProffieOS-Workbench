@inject SaberStateService State
@inject ISnackbar Snackbar
@implements IDisposable

<div class="presets-bar">
    <div class="presets-bar-scroll">
        @for (var i = 0; i < State.Presets.Count; i++)
        {
            var idx = i;
            var preset = State.Presets[i];
            var isActive = idx == State.CurrentPresetIndex;

            <MudPaper Class="@($"saber-card presets-bar-card{(isActive ? " active" : "")}")"
                      Elevation="0"
                      draggable="@(IsEditMode ? "true" : "false")"
                      @ondragstart="@(_ => StartDrag(idx))"
                      @ondrop="@(_ => Drop(idx))"
                      @ondragover:preventDefault="true"
                      @onclick="@(_ => SelectPreset(idx))"
                      @ondblclick="@(_ => { if (IsEditMode) EditPreset(idx); })">
                <span class="preset-index">@(idx + 1)</span>
                <span class="starjedi-title card-title">@preset.Name.Replace("\\n", "\n")</span>
            </MudPaper>
        }

        @if (IsEditMode)
        {
            <MudPaper Class="saber-card presets-bar-card action-card"
                      Elevation="0"
                      @onclick="AddPreset">
                <span class="card-symbol">+</span>
            </MudPaper>

            <MudPaper Class="saber-card presets-bar-card action-card danger-card"
                      Elevation="0"
                      @ondrop="DropDelete"
                      @ondragover:preventDefault="true"
                      @onclick="ConfirmDelete">
                <MudIcon Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" />
            </MudPaper>
        }
    </div>
</div>
