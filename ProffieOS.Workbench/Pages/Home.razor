@page "/"
@inject SaberConnectionService Connection
@inject SaberStateService State
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>ProffieOS Workbench</PageTitle>

<div class="connect-page">
    <div class="connect-logo">
        <span class="starjedi-title">Proffieos<br />Workbench</span>
    </div>

    @if (!Connection.BluetoothAvailable && !Connection.UsbAvailable)
    {
        <MudAlert Severity="Severity.Error" Style="max-width:440px;">
            This browser supports neither Web Bluetooth nor WebUSB.
            Use a Chromium-based browser (Chrome, Edge).
        </MudAlert>
    }

    <div class="connect-section-divider">select connection protocol</div>

    <div class="connect-buttons">
        @if (Connection.UsbAvailable)
        {
            <div class="connect-card @(_busy ? "connect-card-busy" : "")"
                 @onclick="ConnectUsbAsync">
                @if (_busy && _connectingVia == "usb")
                {
                    <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Usb" Class="connect-card-icon" />
                }
                <span class="connect-card-title">usb</span>
                <span class="connect-card-sub">wired protocol</span>
            </div>
        }

        @if (Connection.BluetoothAvailable)
        {
            <div class="connect-card @(_busy ? "connect-card-busy" : "")"
                 @onclick="TogglePasswordField">
                @if (_busy && _connectingVia == "ble")
                {
                    <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Bluetooth" Class="connect-card-icon" />
                }
                <span class="connect-card-title">ble</span>
                <span class="connect-card-sub">wireless protocol</span>
            </div>
        }
    </div>

    @if (_showPassword)
    {
        <div class="password-area">
            <MudTextField @bind-Value="_password"
                          Label="Password (optional)"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="password-field"
                          OnKeyDown="OnPasswordKeyDown" />
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Class="saber-btn"
                       Disabled="_busy"
                       OnClick="ConnectBleAsync">
                @if (_busy && _connectingVia == "ble")
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                connect
            </MudButton>
        </div>
    }

    <div class="connect-section-divider">previously paired</div>
    <KnownDevicesPanel Disabled="_busy" OnConnect="ConnectKnownAsync" />
</div>
