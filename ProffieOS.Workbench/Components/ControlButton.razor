@inject SaberStateService State

<button class="control-btn @(Active ? "is-active" : "")" type="button" @onclick="HandleClick">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <MudIcon Icon="@Icon" Class="control-btn-icon" />
    }
    <span class="control-btn-label starjedi-title">@Label</span>
</button>
