@inject SaberStateService State
@inject ISnackbar Snackbar

<MudPaper Class="saber-card edit-card" Elevation="0">
    <MudText Typo="Typo.caption" Class="field-label starjedi-title">variation</MudText>

    <MudSlider T="int" Value="_value"
               Min="0" Max="32767"
               Class="variation-slider"
               ValueChanged="OnSliderChanged" />

    <div class="variation-row">
        <MudIconButton Icon="@Icons.Material.Filled.Remove"
                       Size="Size.Small"
                       Class="saber-icon-btn"
                       OnClick="Decrement" />

        <MudNumericField T="int" Value="_value"
                         Min="0" Max="32767"
                         Variant="Variant.Outlined"
                         Class="saber-input variation-input"
                         ValueChanged="OnInputChanged" />

        <MudIconButton Icon="@Icons.Material.Filled.Add"
                       Size="Size.Small"
                       Class="saber-icon-btn"
                       OnClick="Increment" />
    </div>
</MudPaper>

@code {
    [Parameter, EditorRequired] public int PresetIndex { get; set; }

    private int _value;

    protected override void OnParametersSet()
    {
        if (PresetIndex >= 0 && PresetIndex < State.Presets.Count)
        {
            if (int.TryParse(State.Presets[PresetIndex].Variation, out var v))
                _value = v;
        }
    }

    private async Task OnSliderChanged(int val)
    {
        _value = val;
        await Save();
    }

    private async Task OnInputChanged(int val)
    {
        _value = val & 32767;
        await Save();
    }

    private async Task Decrement()
    {
        _value = (_value - 1) & 32767;
        await Save();
    }

    private async Task Increment()
    {
        _value = (_value + 1) & 32767;
        await Save();
    }

    private async Task Save()
    {
        try { await State.SaveVariationAsync(PresetIndex, _value); }
        catch (Exception ex) { Snackbar.Add($"Variation error: {ex.Message}", Severity.Error); }
    }
}
