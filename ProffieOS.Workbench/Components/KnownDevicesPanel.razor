@inject IJSRuntime JS

<div class="known-devices">
    <div class="known-devices-title">known devices</div>
    @if (_devices.Count == 0)
    {
        <div class="known-devices-empty">none</div>
    }
    else
    {
        <MudList T="string" Dense="true" Style="background:transparent; width:100%; padding:0;">
            @foreach (var d in _devices)
            {
                var device = d;
                <MudListItem T="string"
                             Disabled="Disabled"
                             OnClick="@(async _ => await OnConnect.InvokeAsync(device))"
                             Style="border:1px solid rgba(26,100,180,0.30); border-radius:4px 20px; margin:3px 0; background:rgba(3,10,30,0.88); padding:6px 14px;">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Outlined"
                                 Color="Color.Primary"
                                 Style="font-family:StarJedi,sans-serif; font-size:0.68rem; height:20px; min-width:36px;">
                            @d.type
                        </MudChip>
                        <span style="font-size:0.88rem; color:#c0dcff; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@d.name</span>
                    </div>
                </MudListItem>
            }
        </MudList>
    }
</div>
