@page "/settings"
@inject SaberConnectionService Connection
@inject SaberStateService State
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>proffieos workbench – settings</PageTitle>

@if (Connection.State == ConnectionState.Disconnected)
{
    <div class="status-shell panel-surface">
        <h1 class="starjedi-title status-title">disconnected</h1>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="saber-btn"
                   OnClick="@(() => Nav.NavigateTo(""))">
            reconnect
        </MudButton>
    </div>
    return;
}

<div class="page-shell">
    <header class="topbar panel-surface">
        <MudTooltip Text="back to dashboard" Placement="Placement.Bottom" Delay="400">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           Class="deck-icon-btn"
                           OnClick="@(() => Nav.NavigateTo("dashboard"))" />
        </MudTooltip>
        <div class="topbar-brand">
            <p class="eyebrow">system configuration</p>
            <span class="starjedi-title wb-title">settings</span>
        </div>
    </header>

    <div class="settings-layout">
        @if (_isLoading)
        {
            <div class="loading-wrap panel-surface">
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else
        {
            <SettingsPanel />
        }
    </div>
</div>
