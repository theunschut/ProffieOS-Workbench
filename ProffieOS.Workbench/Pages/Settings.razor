@page "/settings"
@inject SaberConnectionService Connection
@inject SaberStateService State
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>ProffieOS Workbench – Settings</PageTitle>

@if (Connection.State == ConnectionState.Disconnected)
{
    <div class="hs-screen">
        <div class="hs-brand">
            <span class="starjedi-title hs-title">disconnected</span>
        </div>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="saber-btn"
                   OnClick="@(() => Nav.NavigateTo(""))">
            reconnect
        </MudButton>
    </div>
    return;
}

<header class="wb-header">
    <MudTooltip Text="Back to dashboard" Placement="Placement.Bottom" Delay="400">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       Class="wb-icon-btn"
                       OnClick="@(() => Nav.NavigateTo("dashboard"))" />
    </MudTooltip>
    <span class="starjedi-title wb-title">settings</span>
    <div class="wb-header-spacer"></div>
</header>

<div class="dashboard-panels">
    @if (_isLoading)
    {
        <div class="panel settings-panel">
            <div class="pa-4">
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            </div>
        </div>
    }
    else
    {
        <SettingsPanel />
    }
</div>
