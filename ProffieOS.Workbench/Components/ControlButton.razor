@inject SaberStateService State

<MudPaper Class="@($"control-btn{(Active ? " active" : "")}")"
          Elevation="0"
          @onclick="HandleClick">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <MudIcon Icon="@Icon" Class="control-btn-icon" />
    }
    <span class="control-btn-label">@Label</span>
</MudPaper>
