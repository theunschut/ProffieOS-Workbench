@inject SaberStateService State
@inject ISnackbar Snackbar
@implements IDisposable

<div class="panel work-panel settings-panel">
    <div class="panel-topline">
        <span class="panel-dot"></span>
        <span class="panel-topline-text">settings</span>
    </div>
    <div class="panel-scroll">
        <div class="settings-groups">

            @if (HasSystemSettings)
            {
                <section class="settings-category">
                    <MudText Typo="Typo.subtitle2" Class="starjedi-title settings-category-title">system</MudText>
                    <div class="edit-fields settings-category-grid">
                        <MudPaper Class="field-card" Elevation="0">
                            <div class="setting-row">
                                <MudText Class="starjedi-title setting-label">sd card access</MudText>
                                <MudSwitch T="bool" Value="State.SdEnabled"
                                           Color="Color.Primary"
                                           ValueChanged="SaveSd" />
                            </div>
                        </MudPaper>
                    </div>
                </section>
            }

            @if (HasBladeSettings)
            {
                <section class="settings-category">
                    <MudText Typo="Typo.subtitle2" Class="starjedi-title settings-category-title">blade settings</MudText>
                    <div class="edit-fields settings-category-grid">
                        @if (State.HasBrightness)
                        {
                            <MudPaper Class="field-card" Elevation="0">
                                <MudText Typo="Typo.caption" Class="field-label starjedi-title">
                                    brightness: @State.Brightness%
                                </MudText>
                                <MudSlider T="int" Value="State.Brightness"
                                           Min="1" Max="100"
                                           Class="variation-slider"
                                           ValueChanged="SaveBrightness" />
                            </MudPaper>
                        }

                        @if (State.HasClashThreshold)
                        {
                            <MudPaper Class="field-card" Elevation="0">
                                <MudText Typo="Typo.caption" Class="field-label starjedi-title">
                                    clash threshold: @State.ClashThreshold.ToString("F2")
                                </MudText>
                                <MudSlider T="float" Value="State.ClashThreshold"
                                           Min="0.5f" Max="6.0f" Step="0.05f"
                                           Class="variation-slider"
                                           ValueChanged="SaveClashThreshold" />
                            </MudPaper>
                        }

                        @for (var b = 1; b <= State.BladeLengths.Count; b++)
                        {
                            var blade = b;
                            <MudPaper Class="field-card" Elevation="0">
                                <MudText Typo="Typo.caption" Class="field-label starjedi-title">
                                    blade @blade length
                                </MudText>
                                <MudNumericField T="int"
                                                 Value="State.BladeLengths[blade - 1]"
                                                 Min="0" Max="@State.MaxBladeLength"
                                                 Variant="Variant.Outlined"
                                                 Class="saber-input"
                                                 ValueChanged="@(v => SaveBladeLength(blade, v))" />
                            </MudPaper>
                        }
                    </div>
                </section>
            }

            @if (IgnitionBoolSettings.Any())
            {
                <section class="settings-category">
                    <MudText Typo="Typo.subtitle2" Class="starjedi-title settings-category-title">ignition types</MudText>
                    <div class="edit-fields settings-category-grid">
                        @foreach (var entry in IgnitionBoolSettings)
                        {
                            <MudPaper Class="field-card" Elevation="0">
                                <div class="setting-row">
                                    <MudText Class="starjedi-title setting-label">@entry.Setting.Label.ToLowerInvariant()</MudText>
                                    <MudSwitch T="bool" Value="@entry.Setting.Value"
                                               Color="Color.Primary"
                                               ValueChanged="@(v => SaveBoolGesture(entry.Index, v))" />
                                </div>
                            </MudPaper>
                        }
                    </div>
                </section>
            }

            @if (ActionBoolSettings.Any())
            {
                <section class="settings-category">
                    <MudText Typo="Typo.subtitle2" Class="starjedi-title settings-category-title">gesture actions</MudText>
                    <div class="edit-fields settings-category-grid">
                        @foreach (var entry in ActionBoolSettings)
                        {
                            <MudPaper Class="field-card" Elevation="0">
                                <div class="setting-row">
                                    <MudText Class="starjedi-title setting-label">@entry.Setting.Label.ToLowerInvariant()</MudText>
                                    <MudSwitch T="bool" Value="@entry.Setting.Value"
                                               Color="Color.Primary"
                                               ValueChanged="@(v => SaveBoolGesture(entry.Index, v))" />
                                </div>
                            </MudPaper>
                        }
                    </div>
                </section>
            }

            @if (TimingIntSettings.Any())
            {
                <section class="settings-category">
                    <MudText Typo="Typo.subtitle2" Class="starjedi-title settings-category-title">timings</MudText>
                    <div class="edit-fields settings-category-grid">
                        @foreach (var entry in TimingIntSettings)
                        {
                            <MudPaper Class="field-card" Elevation="0">
                                <MudText Typo="Typo.caption" Class="field-label starjedi-title">@entry.Setting.Label.ToLowerInvariant()</MudText>
                                <MudNumericField T="int" Value="entry.Setting.Value"
                                                 Variant="Variant.Outlined"
                                                 Class="saber-input"
                                                 ValueChanged="@(v => SaveIntGesture(entry.Index, v))" />
                            </MudPaper>
                        }
                    </div>
                </section>
            }

            @if (SensitivityIntSettings.Any())
            {
                <section class="settings-category">
                    <MudText Typo="Typo.subtitle2" Class="starjedi-title settings-category-title">sensitivity</MudText>
                    <div class="edit-fields settings-category-grid">
                        @foreach (var entry in SensitivityIntSettings)
                        {
                            <MudPaper Class="field-card" Elevation="0">
                                <MudText Typo="Typo.caption" Class="field-label starjedi-title">@entry.Setting.Label.ToLowerInvariant()</MudText>
                                <MudNumericField T="int" Value="entry.Setting.Value"
                                                 Variant="Variant.Outlined"
                                                 Class="saber-input"
                                                 ValueChanged="@(v => SaveIntGesture(entry.Index, v))" />
                            </MudPaper>
                        }
                    </div>
                </section>
            }

            @if (OtherBoolSettings.Any() || OtherIntSettings.Any())
            {
                <section class="settings-category">
                    <MudText Typo="Typo.subtitle2" Class="starjedi-title settings-category-title">other settings</MudText>
                    <div class="edit-fields settings-category-grid">
                        @foreach (var entry in OtherBoolSettings)
                        {
                            <MudPaper Class="field-card" Elevation="0">
                                <div class="setting-row">
                                    <MudText Class="starjedi-title setting-label">@entry.Setting.Label.ToLowerInvariant()</MudText>
                                    <MudSwitch T="bool" Value="@entry.Setting.Value"
                                               Color="Color.Primary"
                                               ValueChanged="@(v => SaveBoolGesture(entry.Index, v))" />
                                </div>
                            </MudPaper>
                        }

                        @foreach (var entry in OtherIntSettings)
                        {
                            <MudPaper Class="field-card" Elevation="0">
                                <MudText Typo="Typo.caption" Class="field-label starjedi-title">@entry.Setting.Label.ToLowerInvariant()</MudText>
                                <MudNumericField T="int" Value="entry.Setting.Value"
                                                 Variant="Variant.Outlined"
                                                 Class="saber-input"
                                                 ValueChanged="@(v => SaveIntGesture(entry.Index, v))" />
                            </MudPaper>
                        }
                    </div>
                </section>
            }

        </div>
    </div>
</div>
