@inject SaberStateService State
@inject ISnackbar Snackbar
@implements IDisposable

<div class="preset-dock panel-surface">
    <div class="preset-dock-scroll">
        @for (var i = 0; i < State.Presets.Count; i++)
        {
            var idx = i;
            var preset = State.Presets[i];
            var isActive = idx == State.CurrentPresetIndex;

            <MudPaper Class="@($"preset-chip{(isActive ? " is-active" : "")}")"
                      Elevation="0"
                      draggable="@(IsEditMode ? "true" : "false")"
                      @ondragstart="@(_ => StartDrag(idx))"
                      @ondrop="@(_ => Drop(idx))"
                      @ondragover:preventDefault="true"
                      @onclick="@(_ => SelectPreset(idx))"
                      @ondblclick="@(_ => { if (IsEditMode) EditPreset(idx); })">
                <span class="preset-index">@(idx + 1)</span>
                <span class="starjedi-title preset-name">@preset.Name.Replace("\\n", "\n").ToLowerInvariant()</span>
            </MudPaper>
        }

        @if (IsEditMode)
        {
            <MudPaper Class="preset-chip action-chip"
                      Elevation="0"
                      @onclick="AddPreset">
                <span class="chip-symbol">+</span>
            </MudPaper>

            <MudPaper Class="preset-chip action-chip danger-chip"
                      Elevation="0"
                      @ondrop="DropDelete"
                      @ondragover:preventDefault="true"
                      @onclick="ConfirmDelete">
                <MudIcon Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" />
            </MudPaper>
        }
    </div>
</div>
